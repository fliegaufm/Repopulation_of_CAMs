niche_genes <- c("Il34", "Csf1", "Tgfb1", "Tgfb2", "Il33", "Cx3cl1", "Cxcl12")

VlnPlot(
  niche_only, features = niche_genes, split.by = "timepoint", cols = pal_timepoint,
