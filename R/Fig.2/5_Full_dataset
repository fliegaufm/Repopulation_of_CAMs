# ── 9. Niche factor expression – Violin plots  ────────────────────
niche_celltypes <- c(
  "ven_duEC", "art_duEC", "venousEC", "capillaryEC1", "capillaryEC2",
  "arterialEC", "iegEC",
  "periostalFB", "duFB1", "duFB2", "araFB", "pialFB", "pvFB1", "pvFB2",
