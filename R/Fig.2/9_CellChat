# Ctx/Lm cell types (as original)
lm_ctx_cell_types <- c(
  "arterialEC", "arterialVSMC", "capillaryEC1", "capillaryEC2", "clMonocyte",
  "diffMac", "dividingMac1", "dividingMac2", "homMG", "iegEC", "Lyve1_CAM",
