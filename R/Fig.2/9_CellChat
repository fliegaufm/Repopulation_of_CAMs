)

# ── 1. Load full annotated dataset ───────────────────────────────────────────
full <- readRDS(INPUT_RDS)
cat("Loaded full dataset:", dim(full), "\n")

# ── 2. Define processing function ────────────────────────────────────────────
process_seurat_cellchat <- function(seurat_obj, cell_types, tissue_name, timepoint) {
  # Start timing
  ptm <- Sys.time()
  
  # Seurat preprocessing
  seurat_obj <- FindVariableFeatures(seurat_obj, selection.method = "vst", nfeatures = 5000)
  seurat_obj <- ScaleData(seurat_obj)
  seurat_obj <- RunPCA(seurat_obj)
  
  pdf(file.path(FIGURES_DIR, paste0(tissue_name, "_", timepoint, "_elbow.pdf")), width = 6, height = 4)
  ElbowPlot(seurat_obj, ndims = 30)
  dev.off()
  
  # Dimensionality reduction & clustering
  seurat_obj <- RunUMAP(seurat_obj, dims = 1:20, reduction = "pca")
  seurat_obj <- FindNeighbors(seurat_obj, dims = 1:20, reduction = "pca")
  seurat_obj <- FindClusters(seurat_obj, resolution = 1)
  
  # Conditional Harmony integration (only for Ctx/Lm)
  if (tissue_name == "Ctx/Lm") {
    in_split <- seurat_obj
    in_split[["RNA"]] <- split(in_split[["RNA"]], f = in_split$run)
    in_integrated <- IntegrateLayers(
      in_split,
      method = HarmonyIntegration,
      orig.reduction = "pca",
      new.reduction = "harmony"
    )
    
    # Post-Harmony visualization
    in_integrated <- RunUMAP(in_integrated, reduction = "harmony", dims = 1:20)
    in_integrated <- FindNeighbors(in_integrated, dims = 1:20, reduction = "harmony")
    in_integrated <- FindClusters(in_integrated, resolution = 1)
  } else {
    in_integrated <- seurat_obj
  }
  
  # Quick Seurat visualization (saved per object)
  pdf(file.path(FIGURES_DIR, paste0(tissue_name, "_", timepoint, "_qc_umaps.pdf")), width = 12, height = 10)
  print(DimPlot(in_integrated, group.by = "run", label = TRUE))
  print(DimPlot(in_integrated, reduction = "umap", group.by = "timepoint", label = TRUE))
  print(DimPlot(in_integrated, reduction = "umap", group.by = "tissue", label = TRUE))
  print(DimPlot(in_integrated, reduction = "umap", group.by = "cell_subtype_final", label = TRUE))
  dev.off()
  
  # CellChat workflow
  DefaultAssay(in_integrated) <- "RNA"
  Idents(in_integrated) <- "cell_subtype_final"
  in_integrated <- JoinLayers(in_integrated)
  
  cellchat <- createCellChat(
    object   = in_integrated,
    meta     = in_integrated@meta.data,
    group.by = "cell_subtype_final"
  )
  
  CellChatDB <- CellChatDB.mouse
  cellchat@DB <- CellChatDB
  
  # Preprocessing & inference
  cellchat <- subsetData(cellchat)
  cellchat <- identifyOverExpressedGenes(cellchat)
  cellchat <- identifyOverExpressedInteractions(cellchat)
  cellchat <- projectData(cellchat, PPI.mouse)
  
  cellchat <- computeCommunProb(cellchat)
  cellchat <- filterCommunication(cellchat, min.cells = 5)
  
  cellchat <- computeCommunProbPathway(cellchat)
  cellchat <- aggregateNet(cellchat)
  
  # Extract communication data
  df.net <- subsetCommunication(cellchat)
  
  # Execution time
  execution.time <- Sys.time() - ptm
  cat("Processing time for", tissue_name, timepoint, ":", execution.time, "\n")
  
  return(cellchat)
}

# ── 3. Subset & process Ctx/Lm by timepoint ───────────────────────────────────
ctx_lm <- subset(full, tissue %in% c("Ctx", "Lm"))
ctx_lm <- subset(ctx_lm, cell_subtype_final %in% lm_ctx_cell_types)

ctx_lm_ctl <- subset(ctx_lm, timepoint == "CTL")
ctx_lm_d5  <- subset(ctx_lm, timepoint == "d5")
ctx_lm_8w  <- subset(ctx_lm, timepoint == "8w")

# Process each timepoint
cellchat_ctx_lm_ctl <- process_seurat_cellchat(ctx_lm_ctl, lm_ctx_cell_types, "Ctx/Lm", "CTL")
cellchat_ctx_lm_d5  <- process_seurat_cellchat(ctx_lm_d5,  lm_ctx_cell_types, "Ctx/Lm", "d5")
cellchat_ctx_lm_8w  <- process_seurat_cellchat(ctx_lm_8w,  lm_ctx_cell_types, "Ctx/Lm", "8w")

# ── 4. Merge CellChat objects ─────────────────────────────────────────────────
cellchat_ctx_lm_merged <- mergeCellChat(
  list(cellchat_ctx_lm_ctl, cellchat_ctx_lm_d5, cellchat_ctx_lm_8w),
  add.names = c("Ctx_Lm_CTL", "Ctx_Lm_d5", "Ctx_Lm_8w")
)

object.list.lm <- list(
  Ctx_Lm_CTL = cellchat_ctx_lm_ctl,
  Ctx_Lm_d5  = cellchat_ctx_lm_d5,
  Ctx_Lm_8w  = cellchat_ctx_lm_8w
)

# Save merged and individual objects
saveRDS(cellchat_ctx_lm_merged, file.path(OUTPUT_DIR, "CellChat_Ctx_Lm_SplitbyTimepoints.rds"))
saveRDS(cellchat_ctx_lm_ctl,     file.path(OUTPUT_DIR, "cellchat_ctx_lm_ctl.rds"))
saveRDS(cellchat_ctx_lm_d5,      file.path(OUTPUT_DIR, "cellchat_ctx_lm_d5.rds"))
saveRDS(cellchat_ctx_lm_8w,      file.path(OUTPUT_DIR, "cellchat_ctx_lm_8w.rds"))
saveRDS(object.list.lm,          file.path(OUTPUT_DIR, "object_list_lm.rds"))

