# ── 6. Color palette for visualization ────────────────────────────────────────
set.seed(10)
pal <- createPalette(45, seedcolors = c("#4477AA", "#EE6677", "#228833", "#CCBB44", "#66CCEE", "#AA3377", "#BBBBBB"))
cell_types <- sort(unique(full$cell_subtype_final))
names(pal) <- cell_types

# Subset palette to match d5 (full set)
pal_use_subset <- pal[names(pal) %in% object.list.lm$Ctx_Lm_d5@meta$cell_subtype_final]

# ── 7. Differential interaction analysis ──────────────────────────────────────
# Compare overall interactions across timepoints
pdf(file.path(FIGURES_DIR, "compare_interactions_weight.pdf"), width = 8, height = 6)
compareInteractions(cellchat_ctx_lm_merged, show.legend = FALSE, group = c(1,2,3), measure = "weight")
dev.off()

# DEG-based signalling analysis (d5 as positive dataset)
pos.dataset <- "Ctx_Lm_d5"
features.name <- pos.dataset

cellchat_ctx_lm_merged <- identifyOverExpressedGenes(
  cellchat_ctx_lm_merged,
  group.dataset = "datasets",
  pos.dataset   = pos.dataset,
  features.name = features.name,
  only.pos      = FALSE,
  thresh.pc     = 0.1,
  thresh.fc     = 0.1,
  thresh.p      = 1
)

net <- netMappingDEG(cellchat_ctx_lm_merged, features.name = features.name)

net.up <- subsetCommunication(
  cellchat_ctx_lm_merged,
  net = net,
  datasets = "Ctx_Lm_d5",
  ligand.logFC = 0.1,
  receptor.logFC = NULL
)

net.down <- subsetCommunication(
  cellchat_ctx_lm_merged,
  net = net,
  datasets = "Ctx_Lm_d5",
  ligand.logFC = -0.01,
  receptor.logFC = -0.1
)

net.up.filtered   <- net.up[net.up$prob > 0.1 & net.up$pval < 0.05, ]
net.down.filtered <- net.down[net.down$prob > 0.1 & net.down$pval < 0.05, ]

# ── 8. Chord plots – top interactions ─────────────────────────────────────────
pdf(file.path(FIGURES_DIR, "chord_upregulated_d5_mac_to_monocyte.pdf"), width = 10, height = 8)
