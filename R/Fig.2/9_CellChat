  object.list.lm$Ctx_Lm_d5,
  sources.use = c("diffMac", "dividingMac1", "dividingMac2", "repopMG1", "repopMG2"),
  targets.use = c("clMonocyte"),
  slot.name   = "net",
  net         = net.up.filtered,
  small.gap   = 3.5,
  lab.cex     = 0.8,
  legend.pos.x = 10,
  title.name  = "Up-regulated signaling in Ctx_Lm_d5 (Mac → Monocyte)",
  color.use   = pal_use_subset
)
dev.off()

