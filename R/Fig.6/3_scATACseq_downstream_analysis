# ── 4. Differential accessibility – treatment comparison ──────────────────────
DefaultAssay(atac_wpeaks) <- "called_peaks"

compare_treatments <- function(object, celltype1, celltype2) {
  message(glue("Comparing {celltype1} vs {celltype2}..."))
  
  markers <- FindMarkers(
    object       = object,
    ident.1      = celltype1,
    ident.2      = celltype2,
    only.pos     = FALSE,
    min.pct      = 0.1,
    logfc.threshold = 0.25,
    test.use     = "LR",
    latent.vars  = c("nCount_peaks")
  )
  
  markers <- tibble::rownames_to_column(markers, "peak")
  
  gene_annotated <- ClosestFeature(object, regions = markers$peak) %>%
    as.data.frame() %>%
    dplyr::rename(peak = query_region)
  
  annotated <- left_join(markers, gene_annotated[, c("peak", "gene_name")], by = "peak") %>%
    mutate(gene_label = ifelse(is.na(gene_name), peak, gene_name))
  
  p_volc <- EnhancedVolcano(
    annotated,
    lab       = annotated$gene_label,
    x         = "avg_log2FC",
    y         = "p_val_adj",
    title     = glue("{celltype1} vs {celltype2}"),
    subtitle  = "Differential chromatin accessibility",
    pCutoff   = 0.05,
    FCcutoff  = 0.5,
    pointSize = 2.5,
    labSize   = 1,
    legendPosition = "right",
    drawConnectors = FALSE,
    shape     = 16,
    col       = c("black", "black", "black", "red3")
  )
  
  print(p_volc)
  
  return(annotated)
}

