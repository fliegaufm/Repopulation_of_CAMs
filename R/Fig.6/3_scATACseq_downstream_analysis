motif_name_df <- data.frame(
  motif   = names(motif_object@motif.names),
  TF_name = as.character(motif_object@motif.names),
  stringsAsFactors = FALSE
)

chromvar_markers <- chromvar_markers %>%
  left_join(motif_name_df, by = "motif")

top_hsc <- chromvar_markers %>%
  filter(p_val_adj < 0.005, avg_log2FC > 0) %>%
  slice_min(order_by = p_val_adj, n = 10) %>%
  mutate(group = "hscCAM")

top_ys <- chromvar_markers %>%
  filter(p_val_adj < 0.005, avg_log2FC < 0) %>%
  slice_min(order_by = p_val_adj, n = 10) %>%
  mutate(group = "hom_ysCAM")

top_chromvar <- bind_rows(top_hsc, top_ys)

pdf(file.path(FIGURES_DIR, "feature_plots_top_chromvar_motifs.pdf"), width = 12, height = 10)
plots <- lapply(seq_along(top_chromvar$motif), function(i) {
  FeaturePlot(
