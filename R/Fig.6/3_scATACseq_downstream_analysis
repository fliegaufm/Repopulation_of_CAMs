# ── 8. Motif analysis ─────────────────────────────────────────────────────────
pfm <- getMatrixSet(x = JASPAR2020, opts = list(collection = "CORE", species = "Mus musculus", all_versions = FALSE))

atac_wmotifs <- AddMotifs(
  object = atac_wpeaks,
  genome = BSgenome.Mmusculus.UCSC.mm10,
  pfm    = pfm,
  assay  = "called_peaks"
)

# Filter to standard chromosomes
std_chrs <- paste0("chr", c(1:19, "X", "Y", "M"))
atac_wmotifs <- subset(atac_wmotifs, features = rownames(atac_wmotifs)[seqnames(atac_wmotifs) %in% std_chrs])

saveRDS(atac_wmotifs, file.path(RDS_DIR, "atac_with_motifs_SMALL.rds"))

# Example differential motif enrichment (hscCAM vs hom_ysCAM)
da_peaks_cam <- FindMarkers(
  atac_wmotifs,
  assay    = "called_peaks",
  ident.1  = "hscCAM",
  ident.2  = "hom_ysCAM"
)

da_peaks_cam_sig <- da_peaks_cam[da_peaks_cam$p_val_adj < 0.05, ]
da_peaks_cam_sig$peak <- rownames(da_peaks_cam_sig)

hsc_up <- da_peaks_cam_sig$peak[da_peaks_cam_sig$avg_log2FC > 0]
hsc_up <- hsc_up[hsc_up %in% rownames(atac_wmotifs)]

ys_up <- da_peaks_cam_sig$peak[da_peaks_cam_sig$avg_log2FC < 0]
ys_up <- ys_up[ys_up %in% rownames(atac_wmotifs)]

motifs_hsc <- if (length(hsc_up) > 0) FindMotifs(atac_wmotifs, features = hsc_up) else NULL
motifs_ys  <- if (length(ys_up) > 0)  FindMotifs(atac_wmotifs, features = ys_up)  else NULL

motif_results <- list(hscCAM_up = motifs_hsc, hom_ysCAM_up = motifs_ys)
motif_results <- motif_results[!sapply(motif_results, is.null)]

motif_enrichment <- do.call(rbind, lapply(names(motif_results), function(grp) {
  df <- motif_results[[grp]] %>%
    mutate(group = grp, neg_log_pvalue = -log10(pvalue))
  df
}))

top_motifs <- motif_enrichment %>%
  group_by(group) %>%
  slice_max(order_by = neg_log_pvalue, n = 20) %>%
  ungroup()

pdf(file.path(FIGURES_DIR, "barplot_top_enriched_motifs.pdf"), width = 12, height = 8)
ggplot(top_motifs,
       aes(x = tidytext::reorder_within(motif.name, neg_log_pvalue, group),
           y = neg_log_pvalue,
           fill = fold.enrichment)) +
  geom_bar(stat = "identity") +
  coord_flip() +
  facet_wrap(~ group, scales = "free_y") +
  scale_fill_viridis_c(option = "G", trans = "log10", name = "fold.enrichment") +
  tidytext::scale_x_reordered() +
  theme_minimal() +
  labs(x = "Motif (TF)", y = "-log10(p-value)", title = "Top Enriched Motifs per Group")
dev.off()

