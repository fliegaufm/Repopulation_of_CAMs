# =============================================================================
# Project:   Bulk RNA-seq – LPS treatment in WT + Ccr2-KO model
# Script:    bulkRNAseq_LPS_WT_KO_analysis.R
# Author:    MAximilian Fliegauf
# Date:      11/2024
# Purpose:   Load WT + KO counts & metadata → QC → gene filtering (ribosomal/mito/
#            pseudo/patterns) → batch correction (ComBat-seq) → DESeq2 analysis
#            (full dataset + LPS vs CTL contrasts) → volcano plots → bar plots of
#            DEGs (WT vs KO).
#
# =============================================================================

suppressPackageStartupMessages({
  library(DESeq2)
  library(ggplot2)
  library(pheatmap)
  library(writexl)
  library(dplyr)
  library(tidyr)
  library(tidyheatmaps)
  library(tibble)
  library(ggrepel)
  library(apeglm)
  library(gridExtra)
  library(clusterProfiler)
  library(org.Mm.eg.db)
  library(plotly)
  library(AnnotationDbi)
  library(msigdbr)
  library(readxl)
  library(openxlsx)
  library(EnhancedVolcano)
  library(RColorBrewer)
  library(biomaRt)
  library(VennDiagram)
  library(sva)           # ComBat_seq
})

# ── Paths & Parameters ───────────────────────────────────────────────────────
here::i_am("analysis/bulkRNAseq_LPS_WT_KO_analysis.R")

COUNTS_KO_FILE   <- here("data/raw/counts_Ccr2KO.txt")
COL_DATA_KO_FILE <- here("data/raw/colData_Ccr2KO.txt")
COUNTS_WT_FILE   <- here("data/raw/counts_LPS_yo.txt")
COL_DATA_WT_FILE <- here("data/raw/colData_LPS_yo.txt")

TABLES_DIR  <- here("results/tables/bulkRNAseq_WT_KO")
FIGURES_DIR <- here("results/figures/bulkRNAseq_WT_KO")

dir.create(TABLES_DIR,  recursive = TRUE, showWarnings = FALSE)
dir.create(FIGURES_DIR, recursive = TRUE, showWarnings = FALSE)

# ── 1. Load WT + KO counts & metadata ────────────────────────────────────────
count_data_KO <- read.table(COUNTS_KO_FILE, header = TRUE, row.names = 1, sep = "\t")
colData_KO    <- read.table(COL_DATA_KO_FILE, header = TRUE, sep = "\t")

count_data_yo <- read.table(COUNTS_WT_FILE, header = TRUE, row.names = 1, sep = "\t")
colData_yo    <- read.table(COL_DATA_WT_FILE, header = TRUE, sep = "\t")

# Assign genotype
colData_KO$genotype <- "KO"
colData_yo$genotype <- "WT"

# Match column names
colnames(count_data_KO) <- colData_KO$Sample
colnames(count_data_yo) <- colData_yo$Sample

# ── 2. Combine colData & create combined factors ──────────────────────────────
# Add missing columns to colData_KO
missing_cols <- setdiff(colnames(colData_yo), colnames(colData_KO))
for (col in missing_cols) {
  colData_KO[[col]] <- NA
}

# Reorder columns to match
colData_KO <- colData_KO[, colnames(colData_yo)]

# rbind
colData_combined <- rbind(colData_yo, colData_KO)

# Create combined factors
colData_combined <- colData_combined %>%
  mutate(
    combined = paste0(combined, "_", genotype),
    grou     = paste(Treatment, Condition, sep = "_")
  )

colData_combined$grou <- factor(colData_combined$grou)

# ── 3. Combine count data ────────────────────────────────────────────────────
count_data_combined <- merge(
  count_data_KO, count_data_yo,
  by = "row.names", all = TRUE
)

rownames(count_data_combined) <- count_data_combined$Row.names
count_data_combined <- count_data_combined[, -1]
count_data_combined[is.na(count_data_combined)] <- 0

# ── 5. Quality Control ───────────────────────────────────────────────────────
total_counts <- colSums(count_data_combined)
summary(total_counts)

pdf(file.path(FIGURES_DIR, "library_sizes_WT_KO.pdf"), width = 10, height = 6)
barplot(total_counts, main = "Library Sizes WT and KO", col = "lightblue", las = 2)
dev.off()

# ── 6. General filtering & batch correction ──────────────────────────────────
# Basic filter: ≥10 counts in ≥ half of samples
count_filtered_comb <- count_data_combined[rowSums(count_data_combined > 10) >= ncol(count_data_combined)/2, ]

# Batch column
colData_combined$batch <- ifelse(
  colData_combined$Sample %in% c("1_CAM", "4_CAM", "6_CAM", "9_CAM", "12_CAM", "14_CAM"),
  "Batch1", "Batch2"
)

# Model matrix for known covariates
mod <- model.matrix(~ genotype + cell_type, data = colData_combined)

# ComBat-seq batch correction
count_data_cor <- ComBat_seq(
  counts     = as.matrix(count_filtered_comb),
  batch      = colData_combined$batch,
  group      = colData_combined$grou,
  covar_mod  = mod
)

# ── 7. Gene filtering (ribosomal, mitochondrial, pseudogenes, patterns) ───────
ribo_genes <- msigdbr(species = "Mus musculus", category = "C2") %>%
  filter(gs_name == "KEGG_RIBOSOME") %>% pull(gene_symbol)

mito_genes <- msigdbr(species = "Mus musculus", category = "C2") %>%
  filter(gs_name == "KEGG_OXIDATIVE_PHOSPHORYLATION") %>% pull(gene_symbol)

mart <- useMart("ensembl", dataset = "mmusculus_gene_ensembl", host = "https://www.ensembl.org")

pseudo_genes <- getBM(attributes = c("external_gene_name"),
                      filters = "biotype",
                      values = c("pseudogene", "predicted", "novel", "uncharacterized"),
                      mart = mart) %>% pull(external_gene_name)

noncoding_genes <- getBM(attributes = c("external_gene_name"),
                         filters = "biotype",
                         values = c("lincRNA", "miRNA", "snRNA", "snoRNA"),
                         mart = mart) %>% pull(external_gene_name)

patterns <- c("Mrp", "Rpl", "Rps", "Sn", "Sf", "Gtf", "Med", "Rbm", "Rik",
              "Lsm", "Eif", "Atp", "Nduf", "Tomm", "Pol", "Rna", "Gm", "Ddx",
              "Smim", "Zfp", "Dna", "Timm")

pattern_genes <- grep(paste(patterns, collapse = "|"), rownames(count_data_cor), value = TRUE)

ex_genes <- unique(c(ribo_genes, mito_genes, pseudo_genes, noncoding_genes, pattern_genes))

count_filtered_comb <- count_data_cor[!rownames(count_data_cor) %in% ex_genes, ]

cat("Genes excluded:", length(ex_genes), "\n")
cat("Remaining genes:", nrow(count_filtered_comb), "\n")

# ── 8. DESeq2 – Full dataset ─────────────────────────────────────────────────
design_formula <- ~ grou + genotype + cell_type

dds <- DESeqDataSetFromMatrix(
  countData = count_filtered_comb,
  colData   = colData_combined,
  design    = design_formula
)

dds <- estimateSizeFactors(dds)
dds <- DESeq(dds)

# VST for visualization
vsd <- vst(dds, blind = FALSE)

# ── 9. PCA & unbiased heatmap ────────────────────────────────────────────────
pca_data <- plotPCA(vsd, intgroup = c("grou", "cell_type", "genotype"), returnData = TRUE, ntop = 150)
percent_var <- round(100 * attr(pca_data, "percentVar"))

p_pca <- ggplot(pca_data, aes(PC1, PC2, color = genotype, shape = cell_type, fill = grou)) +
  geom_point(size = 3, stroke = 1) +
  xlab(paste0("PC1: ", percent_var[1], "% variance")) +
  ylab(paste0("PC2: ", percent_var[2], "% variance")) +
  labs(title = "PCA of RNA-seq Data (WT + KO)") +
  scale_shape_manual(values = c(21, 22, 24)) +
  scale_color_manual(values = c("black", "grey")) +
  scale_fill_manual(values = brewer.pal(n = length(unique(pca_data$grou)), name = "Set2")) +
  guides(fill = guide_legend(override.aes = list(shape = 21))) +
  guides(shape = guide_legend(override.aes = list(shape = c(16, 15)))) +
  theme_minimal()

ggsave(file.path(FIGURES_DIR, "pca_WT_KO.pdf"), p_pca, width = 8, height = 6)

# Heatmap – top 250 variable genes
vsd_mat <- assay(vsd)
gene_variances <- apply(vsd_mat, 1, var)
top_genes <- order(gene_variances, decreasing = TRUE)[1:250]
vsd_top <- vsd_mat[top_genes, ]

annotation_col <- as.data.frame(colData_combined[, c("grou", "genotype", "cell_type"), drop = FALSE])
rownames(annotation_col) <- colData_combined$Sample

pheatmap(
  vsd_top,
  scale = "row",
  cluster_rows = TRUE,
  cluster_cols = TRUE,
  fontsize = 5,
  fontsize_row = 3,
  fontsize_col = 8,
  cellwidth = 10,
  annotation_col = annotation_col,
  filename = file.path(FIGURES_DIR, "heatmap_top250_variable_genes.pdf")
)

# ── 10. DESeq2 contrasts – LPS vs CTL (CAM_B vs CAM_V, MG_B vs MG_V) ──────────
design_v <- ~ combined
dds_v <- DESeqDataSetFromMatrix(
  countData = count_filtered_comb,
  colData   = colData_combined,
  design    = design_v
)

dds_v <- estimateSizeFactors(dds_v)
dds_v <- DESeq(dds_v)

# WT – CAM_B vs CAM_V
dds_v$combined <- relevel(dds_v$combined, ref = "CAM_young_V_LPS_WT")
dds_v <- nbinomWaldTest(dds_v)
res <- results(dds_v, name = "combined_CAM_young_BLZ_LPS_WT_vs_CAM_young_V_LPS_WT")
lfc_BvV_WT <- lfcShrink(dds_v, coef = "combined_CAM_young_BLZ_LPS_WT_vs_CAM_young_V_LPS_WT", type = "apeglm")
lfc_BvV_WT$padj <- res$padj

p_volc_BvV_WT <- EnhancedVolcano(
  lfc_BvV_WT,
  lab = rownames(lfc_BvV_WT),
  x = "log2FoldChange", y = "padj",
  pCutoff = 0.05, FCcutoff = 1,
  title = "CAM_B vs CAM_V WT young",
  max.overlaps = Inf, labSize = 2, pointSize = 2, ylim = c(0, 7.5)
)

ggsave(file.path(FIGURES_DIR, "volcano_CAM_B_vs_V_WT.pdf"), p_volc_BvV_WT, width = 8, height = 6)

WT_bar <- length(rownames(lfc_BvV_WT[abs(lfc_BvV_WT$log2FoldChange) > 1 & lfc_BvV_WT$padj < 0.05, ]))

# WT – MG_B vs MG_V
dds_v$combined <- relevel(dds_v$combined, ref = "MG_young_V_LPS_WT")
dds_v <- nbinomWaldTest(dds_v)
res <- results(dds_v, name = "combined_MG_young_BLZ_LPS_WT_vs_MG_young_V_LPS_WT")
lfc_BvV_WT_MG <- lfcShrink(dds_v, coef = "combined_MG_young_BLZ_LPS_WT_vs_MG_young_V_LPS_WT", type = "apeglm")
lfc_BvV_WT_MG$padj <- res$padj

p_volc_BvV_WT_MG <- EnhancedVolcano(
