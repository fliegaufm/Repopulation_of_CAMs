# Chi-square test – CAMs
observed_CAM <- matrix(c(150, 9138, 29, 9259), nrow = 2, byrow = TRUE,
                       dimnames = list(c("WT", "KO"), c("DEGs", "Not_DEGs")))
chi_CAM <- chisq.test(observed_CAM)
cat("CAMs Chi-square statistic:", chi_CAM$statistic, "\n")
cat("CAMs Degrees of freedom:", chi_CAM$parameter, "\n")
cat("CAMs P-value:", chi_CAM$p.value, "\n")

# Chi-square test – MG
observed_MG <- matrix(c(2, 9286, 0, 9288), nrow = 2, byrow = TRUE,
                      dimnames = list(c("WT", "KO"), c("DEGs", "Not_DEGs")))
chi_MG <- chisq.test(observed_MG)
cat("MG Chi-square statistic:", chi_MG$statistic, "\n")
cat("MG Degrees of freedom:", chi_MG$parameter, "\n")
cat("MG P-value:", chi_MG$p.value, "\n")

