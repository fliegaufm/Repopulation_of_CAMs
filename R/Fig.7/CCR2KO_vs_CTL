dds_v <- nbinomWaldTest(dds_v)
res <- results(dds_v, name = "combined_MG_young_BLZ_LPS_KO_vs_MG_young_V_LPS_KO")
lfc_BvV_KO_MG <- lfcShrink(dds_v, coef = "combined_MG_young_BLZ_LPS_KO_vs_MG_young_V_LPS_KO", type = "apeglm")
