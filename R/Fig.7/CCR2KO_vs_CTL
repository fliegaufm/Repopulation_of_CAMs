  lab = rownames(lfc_BvV_WT_MG),
  x = "log2FoldChange", y = "padj",
  pCutoff = 0.05, FCcutoff = 1,
  title = "MG_B vs MG_V WT young",
  max.overlaps = 25, ylim = c(0, 7.5)
