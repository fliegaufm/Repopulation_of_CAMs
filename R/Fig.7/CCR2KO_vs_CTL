ggsave(file.path(FIGURES_DIR, "volcano_MG_B_vs_V_WT.pdf"), p_volc_BvV_WT_MG, width = 8, height = 6)

WT_bar_MG <- length(rownames(lfc_BvV_WT_MG[abs(lfc_BvV_WT_MG$log2FoldChange) > 1 & lfc_BvV_WT_MG$padj < 0.05, ]))

