ggsave(file.path(FIGURES_DIR, "volcano_MG_B_vs_V_KO.pdf"), p_volc_BvV_KO_MG, width = 8, height = 6)

KO_bar_MG <- length(rownames(lfc_BvV_KO_MG[abs(lfc_BvV_KO_MG$log2FoldChange) > 1 & lfc_BvV_KO_MG$padj < 0.05, ]))

# ── 11. Bar plots – DEG counts (WT vs KO) ─────────────────────────────────────
# CAMs
deg_counts_CAM <- c(WT_bar, KO_bar)
names(deg_counts_CAM) <- c("WT_DEGs", "KO_DEGs")

pdf(file.path(FIGURES_DIR, "bar_DEGs_CAM_WT_vs_KO.pdf"), width = 6, height = 6)
