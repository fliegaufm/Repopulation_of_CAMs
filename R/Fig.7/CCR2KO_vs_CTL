dds_v$combined <- relevel(dds_v$combined, ref = "CAM_young_V_LPS_KO")
dds_v <- nbinomWaldTest(dds_v)
res <- results(dds_v, name = "combined_CAM_young_BLZ_LPS_KO_vs_CAM_young_V_LPS_KO")
lfc_BvV_KO <- lfcShrink(dds_v, coef = "combined_CAM_young_BLZ_LPS_KO_vs_CAM_young_V_LPS_KO", type = "apeglm")
