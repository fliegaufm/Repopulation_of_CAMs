# =============================================================================
# Project:   Bulk RNA-seq – LPS treatment in Ccr2-creERT2 × tdT model
# Script:    bulkRNAseq_LPS_Ccr2_analysis.R
# Author:    Maximilian Fliegauf
# Date:      11/2024
# Purpose:   Load counts & metadata → QC → gene filtering (ribosomal/mito/pseudo/patterns)
#            → DESeq2 (full dataset + CAM-only + CTL-only) → volcano plots → GO enrichment
#            → radar/spider plots → Venn diagrams → bar plots of LPS-induced genes.
#
# =============================================================================

suppressPackageStartupMessages({
  library(DESeq2)
  library(ggplot2)
  library(pheatmap)
  library(dplyr)
  library(tidyr)
  library(tibble)
  library(ggrepel)
  library(apeglm)
  library(clusterProfiler)
  library(org.Mm.eg.db)
  library(plotly)
  library(AnnotationDbi)
  library(msigdbr)
  library(EnhancedVolcano)
  library(biomaRt)
  library(fmsb)          # ggradar
  library(scales)
  library(VennDiagram)
})

# ── Paths & Parameters ───────────────────────────────────────────────────────
here::i_am("analysis/bulkRNAseq_LPS_Ccr2_analysis.R")

COUNTS_FILE   <- here("data/raw/counts_LPS_Ccr2.txt")
COL_DATA_FILE <- here("data/raw/colData_LPS_Ccr2.txt")

TABLES_DIR  <- here("results/tables/bulkRNAseq")
FIGURES_DIR <- here("results/figures/bulkRNAseq")

dir.create(TABLES_DIR,  recursive = TRUE, showWarnings = FALSE)
dir.create(FIGURES_DIR, recursive = TRUE, showWarnings = FALSE)

# ── 1. Load raw counts & metadata ────────────────────────────────────────────
count_data <- read.table(COUNTS_FILE, header = TRUE, row.names = 1, sep = "\t")
colData    <- read.table(COL_DATA_FILE, header = TRUE, sep = "\t")

# Match & reorder columns
colnames(count_data) <- colData$Sample
count_data <- count_data[, match(colData$Sample, colnames(count_data))]

# Create combined factors
colData <- colData %>%
  mutate(
    combined  = factor(paste0(Treatment, "_", Condition)),
    combined1 = factor(paste0(cell_type, "_", combined))
  )

# ── 2. Quality Control ───────────────────────────────────────────────────────
total_counts <- colSums(count_data)
summary(total_counts)

pdf(file.path(FIGURES_DIR, "library_sizes.pdf"), width = 10, height = 6)
barplot(total_counts, main = "Library Sizes – Smart-3 Seq Ccr2creERT2×tdT LPS",
        col = "lightblue", las = 2, cex.names = 0.7)
dev.off()

# Filter low-expressed genes (≥10 counts in ≥ half of samples)
count_filtered <- count_data[rowSums(count_data > 10) >= ncol(count_data)/2, ]
cat("Genes after low-count filter:", nrow(count_filtered), "\n")

# ── 3. Gene filtering (ribosomal, mitochondrial, pseudogenes, patterns) ───────
# KEGG pathways
ribo_genes <- msigdbr(species = "Mus musculus", category = "C2") %>%
  filter(gs_name == "KEGG_RIBOSOME") %>% pull(gene_symbol)

mito_genes <- msigdbr(species = "Mus musculus", category = "C2") %>%
  filter(gs_name == "KEGG_OXIDATIVE_PHOSPHORYLATION") %>% pull(gene_symbol)

# biomaRt
mart <- useMart("ensembl", dataset = "mmusculus_gene_ensembl", host = "https://www.ensembl.org")

pseudo_genes <- getBM(attributes = c("external_gene_name"),
                      filters = "biotype",
                      values = c("pseudogene", "predicted", "novel", "uncharacterized"),
                      mart = mart) %>% pull(external_gene_name)

noncoding_genes <- getBM(attributes = c("external_gene_name"),
                         filters = "biotype",
                         values = c("lincRNA", "miRNA", "snRNA", "snoRNA"),
                         mart = mart) %>% pull(external_gene_name)

# Pattern-based exclusion
patterns <- c("Mrp", "Rpl", "Rps", "Sn", "Sf", "Gtf", "Med", "Rbm", "Rik",
              "Lsm", "Eif", "Atp", "Nduf", "Tomm", "Pol", "Anap", "Rna", "Gm", "Ddx",
              "Smim", "Zfp", "Bola", "Dna", "Timm", "Micos")

pattern_genes <- grep(paste(patterns, collapse = "|"), rownames(count_filtered), value = TRUE)

# Combine all exclusion lists
ex_genes <- unique(c(ribo_genes, mito_genes, pseudo_genes, noncoding_genes, pattern_genes))

# Apply filter
count_filtered <- count_filtered[!rownames(count_filtered) %in% ex_genes, ]

cat("Genes excluded:", length(ex_genes), "\n")
cat("Remaining genes:", nrow(count_filtered), "\n")

writeLines(ex_genes, file.path(TABLES_DIR, "excluded_genes.txt"))

# ── 4. DESeq2 – Full dataset ─────────────────────────────────────────────────
design_full <- ~ combined + cell_type

dds <- DESeqDataSetFromMatrix(
  countData = count_filtered,
  colData   = colData,
  design    = design_full
)

dds <- estimateSizeFactors(dds)
dds <- DESeq(dds)

# VST for visualization
vsd <- vst(dds, blind = TRUE)
vsd_mat <- assay(vsd)

# ── 5. PCA & unbiased heatmap (full dataset) ─────────────────────────────────
pca_data <- plotPCA(vsd, intgroup = c("cell_type", "combined"), returnData = TRUE, ntop = 100)
percent_var <- round(100 * attr(pca_data, "percentVar"))

p_pca <- ggplot(pca_data, aes(PC1, PC2, color = cell_type, shape = combined)) +
  geom_point(size = 4, stroke = 1) +
  xlab(paste0("PC1: ", percent_var[1], "% variance")) +
  ylab(paste0("PC2: ", percent_var[2], "% variance")) +
  labs(title = "PCA of RNA-seq Data with Multiple Variables") +
  guides(color = guide_legend(override.aes = list(shape = c(16)))) +
  guides(shape = guide_legend(override.aes = list(shape = c(16, 17)))) +
  theme_minimal()

ggsave(file.path(FIGURES_DIR, "pca_full_dataset.pdf"), p_pca, width = 8, height = 6)

# Heatmap of top 100 most variable genes
gene_variances <- apply(vsd_mat, 1, var)
top_variable_genes <- order(gene_variances, decreasing = TRUE)[1:100]
vsd_mat_top <- vsd_mat[top_variable_genes, ]

annotation_col <- as.data.frame(colData[, c("cell_type", "combined"), drop = FALSE])
rownames(annotation_col) <- colData$Sample

pheatmap(
  vsd_mat_top,
  scale = "row",
  cluster_rows = TRUE,
  cluster_cols = TRUE,
  fontsize = 5,
  fontsize_row = 5,
  fontsize_col = 8,
  annotation_col = annotation_col,
  filename = file.path(FIGURES_DIR, "heatmap_top100_variable_genes.pdf")
)

# ── 6. LPS activation contrasts (MG, tdT-, tdT+) ─────────────────────────────
design_lps <- ~ combined1
dds_lps <- DESeqDataSetFromMatrix(countData = count_filtered, colData = colData, design = design_lps)
dds_lps <- estimateSizeFactors(dds_lps)
dds_lps <- DESeq(dds_lps)

# MG LPS vs CTL
lfc_shrink_MG <- lfcShrink(dds_lps, coef = "combined1_MG_BLZ_LPS_vs_MG_BLZ_CTL", type = "apeglm")

p_volc_mg <- EnhancedVolcano(
  lfc_shrink_MG,
  lab = rownames(lfc_shrink_MG),
  x = "log2FoldChange", y = "padj",
  pCutoff = 0.05, FCcutoff = 1,
  title = "MG: LPS vs CTL"
)
ggsave(file.path(FIGURES_DIR, "volcano_MG_LPS_vs_CTL.pdf"), p_volc_mg, width = 8, height = 6)

# tdT- (neg) LPS vs CTL
dds_lps$combined1 <- relevel(dds_lps$combined1, ref = "neg_BLZ_CTL")
dds_lps <- nbinomWaldTest(dds_lps)
lfc_shrink_neg <- lfcShrink(dds_lps, coef = "combined1_neg_BLZ_LPS_vs_neg_BLZ_CTL", type = "apeglm")

p_volc_neg <- EnhancedVolcano(
  lfc_shrink_neg,
  lab = rownames(lfc_shrink_neg),
  x = "log2FoldChange", y = "padj",
  pCutoff = 0.05, FCcutoff = 1,
  title = "tdT-: LPS vs CTL"
)
ggsave(file.path(FIGURES_DIR, "volcano_neg_LPS_vs_CTL.pdf"), p_volc_neg, width = 8, height = 6)

# tdT+ (pos) LPS vs CTL
dds_lps$combined1 <- relevel(dds_lps$combined1, ref = "pos_BLZ_CTL")
dds_lps <- nbinomWaldTest(dds_lps)
lfc_shrink_pos <- lfcShrink(dds_lps, coef = "combined1_pos_BLZ_LPS_vs_pos_BLZ_CTL", type = "apeglm")

p_volc_pos <- EnhancedVolcano(
  lfc_shrink_pos,
  lab = rownames(lfc_shrink_pos),
  x = "log2FoldChange", y = "padj",
  pCutoff = 0.05, FCcutoff = 1,
  title = "tdT+: LPS vs CTL"
)
ggsave(file.path(FIGURES_DIR, "volcano_pos_LPS_vs_CTL.pdf"), p_volc_pos, width = 8, height = 6)

# ── 7. GO enrichment – LPS upregulated genes ─────────────────────────────────
res_mg  <- results(dds_lps, name = "combined1_MG_BLZ_LPS_vs_MG_BLZ_CTL")
res_neg <- results(dds_lps, name = "combined1_neg_BLZ_LPS_vs_neg_BLZ_CTL")
res_pos <- results(dds_lps, name = "combined1_pos_BLZ_LPS_vs_pos_BLZ_CTL")

background_genes <- rownames(count_filtered)

go_mg_up  <- enrichGO(
  gene = rownames(res_mg)[res_mg$padj < 0.05 & res_mg$log2FoldChange > 0],
  OrgDb = org.Mm.eg.db, universe = background_genes, ont = "BP",
  pAdjustMethod = "BH", pvalueCutoff = 0.2, qvalueCutoff = 0.05,
  minGSSize = 3, keyType = "SYMBOL"
)

go_neg_up <- enrichGO(
  gene = rownames(res_neg)[res_neg$padj < 0.05 & res_neg$log2FoldChange > 0],
  OrgDb = org.Mm.eg.db, universe = background_genes, ont = "BP",
  pAdjustMethod = "BH", pvalueCutoff = 0.2, qvalueCutoff = 0.05,
  minGSSize = 3, keyType = "SYMBOL"
)

go_pos_up <- enrichGO(
  gene = rownames(res_pos)[res_pos$padj < 0.05 & res_pos$log2FoldChange > 0],
  OrgDb = org.Mm.eg.db, universe = background_genes, ont = "BP",
  pAdjustMethod = "BH", pvalueCutoff = 0.2, qvalueCutoff = 0.05,
  minGSSize = 3, keyType = "SYMBOL"
)

ego_mg  <- simplify(go_mg_up,  cutoff = 0.6, by = "p.adjust", measure = "Wang")
ego_neg <- simplify(go_neg_up, cutoff = 0.6, by = "p.adjust", measure = "Wang")
ego_pos <- simplify(go_pos_up, cutoff = 0.6, by = "p.adjust", measure = "Wang")

pdf(file.path(FIGURES_DIR, "GO_LPS_upregulated.pdf"), width = 10, height = 6)

barplot(ego_mg,  showCategory = 10, title = "GO BP: MG LPS vs CTL (Up)") +
  scale_fill_gradient(low = "#00A9FF", high = "white") +
  theme_minimal() +
  geom_bar(stat = "identity", color = "black")

barplot(ego_neg, showCategory = 10, title = "GO BP: tdT- LPS vs CTL (Up)") +
  scale_fill_gradient(low = "#F8766D", high = "white") +
  theme_minimal() +
  geom_bar(stat = "identity", color = "black")

barplot(ego_pos, showCategory = 10, title = "GO BP: tdT+ LPS vs CTL (Up)") +
  scale_fill_gradient(low = "#7CAE00", high = "white") +
  theme_minimal() +
  geom_bar(stat = "identity", color = "black")

dev.off()

# ── 8. CAM-only analysis (pos vs neg in LPS) ──────────────────────────────────
