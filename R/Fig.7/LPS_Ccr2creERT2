# ── 13. Bar plots – LPS-induced genes & highest difference from CTL ───────────
common_LPS_genes <- Reduce(intersect, list(
  rownames(res_mg)[res_mg$padj < 0.05 & res_mg$log2FoldChange > 0],
  rownames(res_neg)[res_neg$padj < 0.05 & res_neg$log2FoldChange > 0],
  rownames(res_pos)[res_pos$padj < 0.05 & res_pos$log2FoldChange > 0]
))

norm_counts_common <- counts(dds, normalized = TRUE)[common_LPS_genes, , drop = FALSE]

mean_common <- data.frame(Gene = rownames(norm_counts_common))
for (cond in unique(colData$combined1)) {
  mean_common[[cond]] <- rowMeans(norm_counts_common[, colData$combined1 == cond, drop = FALSE])
}

mean_common$Higher_In <- colnames(mean_common)[-1][apply(mean_common[,-1], 1, which.max)]

counts_summary <- mean_common %>%
  group_by(Higher_In) %>%
  summarise(Count = n()) %>%
  ungroup()

chi_test <- chisq.test(counts_summary$Count)
p_chi <- format.pval(chi_test$p.value, digits = 2)

condition_colors <- setNames(RColorBrewer::brewer.pal(n = nrow(counts_summary), "Set2"), counts_summary$Higher_In)

p_bar <- ggplot(counts_summary, aes(x = Higher_In, y = Count, fill = Higher_In)) +
  geom_bar(stat = "identity", width = 0.6) +
  labs(title = paste("Overlapping LPS genes – highest in each condition\nChi-square p =", p_chi),
       x = "Condition", y = "Number of genes") +
  scale_fill_manual(values = condition_colors) +
  theme_minimal() +
  theme(legend.position = "none", axis.text.x = element_text(angle = 45, hjust = 1))

ggsave(file.path(FIGURES_DIR, "bar_LPS_highest_condition.pdf"), p_bar, width = 8, height = 6)

# Highest LFC from CTL
comparisons_lfc <- list(
  MG   = c("MG_BLZ_LPS",   "MG_BLZ_CTL"),
  neg  = c("neg_BLZ_LPS",  "neg_BLZ_CTL"),
  pos  = c("pos_BLZ_LPS",  "pos_BLZ_CTL")
)

for (comp in names(comparisons_lfc)) {
  cond_lps  <- comparisons_lfc[[comp]][1]
  cond_ctl  <- comparisons_lfc[[comp]][2]
  mean_common[[paste0(comp, "_LFC")]] <- log2((mean_common[[cond_lps]] + 1) / (mean_common[[cond_ctl]] + 1))
}

lfc_cols <- paste0(names(comparisons_lfc), "_LFC")
mean_common$Max_LFC_Comp <- lfc_cols[apply(abs(mean_common[lfc_cols]), 1, which.max)]

lfc_summary <- mean_common %>%
  group_by(Max_LFC_Comp) %>%
  summarise(Count = n()) %>%
  ungroup()

p_lfc_bar <- ggplot(lfc_summary, aes(x = Max_LFC_Comp, y = Count, fill = Max_LFC_Comp)) +
  geom_bar(stat = "identity", width = 0.6) +
  labs(title = "Genes with highest LFC from CTL", x = "Comparison", y = "Number of genes") +
  scale_fill_manual(values = condition_colors) +
  theme_minimal() +
  theme(legend.position = "none", axis.text.x = element_text(angle = 45, hjust = 1))

ggsave(file.path(FIGURES_DIR, "bar_LPS_highest_LFC_from_CTL.pdf"), p_lfc_bar, width = 8, height = 6)
