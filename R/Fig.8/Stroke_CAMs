# ── Paths & Parameters ───────────────────────────────────────────────────────
here::i_am("analysis/bulkRNAseq_Stroke_CAMs_analysis.R")

COUNTS_FILE   <- here("data/raw/counts.txt")
COL_DATA_FILE <- here("data/raw/colData.txt")

TABLES_DIR  <- here("results/tables/stroke_cams")
FIGURES_DIR <- here("results/figures/stroke_cams")

dir.create(TABLES_DIR,  recursive = TRUE, showWarnings = FALSE)
dir.create(FIGURES_DIR, recursive = TRUE, showWarnings = FALSE)

# ── 1. Load counts & metadata ────────────────────────────────────────────────
count_data <- read.table(COUNTS_FILE, header = TRUE, row.names = 1, sep = "\t")
colData    <- read.table(COL_DATA_FILE, header = TRUE, sep = "\t")

# Reorder columns to match colData
count_data <- count_data[, match(colData$Sample, colnames(count_data))]

# Factorize metadata
colData <- colData %>%
  mutate(
    Hemisphere = factor(Hemisphere),
    Treatment  = factor(Treatment)
  )

# ── 2. Quality Control & sample exclusion ─────────────────────────────────────
total_counts <- colSums(count_data)
summary(total_counts)

pdf(file.path(FIGURES_DIR, "library_sizes_stroke_cams.pdf"), width = 10, height = 6)
barplot(total_counts, main = "Library Sizes Smart-3 Seq Ccr2creERT2×tdT LPS (CAMs)",
        col = "lightblue", las = 2, cex.names = 0.7)
dev.off()

# Exclude poor-quality samples (A3_ipsi, C2_ipsi — degraded RNA)
samples_to_exclude <- c("A3_ipsi", "C2_ipsi")

colData <- colData[!colData$Sample %in% samples_to_exclude, ]
count_data <- count_data[, !colnames(count_data) %in% samples_to_exclude]

# Re-match order
count_data <- count_data[, match(colData$Sample, colnames(count_data))]

# Filter low-expressed genes (≥10 counts in ≥ half of samples)
count_filtered <- count_data[rowSums(count_data > 10) >= ncol(count_data)/2, ]
cat("Genes after low-count filter:", nrow(count_filtered), "\n")

# ── 3. DESeq2 – Full model with interaction ──────────────────────────────────
design_formula <- ~ Treatment + Hemisphere + Treatment*Hemisphere

dds <- DESeqDataSetFromMatrix(
  countData = count_filtered,
  colData   = colData,
  design    = design_formula
)

dds <- estimateSizeFactors(dds)
dds <- DESeq(dds)

# VST for visualization
vsd <- vst(dds, blind = TRUE)

# ── 4. PCA Plot ──────────────────────────────────────────────────────────────
pca_data <- plotPCA(vsd, intgroup = c("Treatment", "Hemisphere"), returnData = TRUE, ntop = 1000)
percent_var <- round(100 * attr(pca_data, "percentVar"))

p_pca <- ggplot(pca_data, aes(PC1, PC2, color = Treatment, shape = Hemisphere)) +
  geom_point(size = 4, stroke = 1) +
  xlab(paste0("PC1: ", percent_var[1], "% variance")) +
  ylab(paste0("PC2: ", percent_var[2], "% variance")) +
  labs(title = "PCA of RNA-seq Data (Stroke CAMs)") +
  guides(color = guide_legend(override.aes = list(shape = c(16)))) +
  guides(shape = guide_legend(override.aes = list(shape = c(16, 17)))) +
  theme_minimal()

ggsave(file.path(FIGURES_DIR, "pca_stroke_cams.pdf"), p_pca, width = 8, height = 6)

# ── 5. Combined contrasts (ipsi vs contra in BLZ945 & Vehicle) ────────────────
colData$combined <- factor(paste0(colData$Treatment, "_", colData$Hemisphere))

design_comb <- ~ combined

dds_comb <- DESeqDataSetFromMatrix(
  countData = count_filtered,
  colData   = colData,
  design    = design_comb
)

dds_comb <- estimateSizeFactors(dds_comb)
dds_comb <- DESeq(dds_comb)

# BLZ945 ipsi vs contra
dds_comb$combined <- relevel(dds_comb$combined, ref = "BLZ945_contralateral")
dds_comb <- nbinomWaldTest(dds_comb)

res_icB <- results(dds_comb, name = "combined_BLZ945_ipsilateral_vs_BLZ945_contralateral")
lfcs_icB <- lfcShrink(dds_comb, coef = "combined_BLZ945_ipsilateral_vs_BLZ945_contralateral", type = "apeglm")

lfcs_icB$Gene <- rownames(lfcs_icB)
lfcs_icB <- na.omit(lfcs_icB)

lfcs_icB$Significance <- ifelse(
  lfcs_icB$padj < 0.05 & abs(lfcs_icB$log2FoldChange) > 0.59, "p-value and log2 fold change",
  ifelse(lfcs_icB$padj < 0.05 & abs(lfcs_icB$log2FoldChange) <= 0.59, "p-value",
         ifelse(abs(lfcs_icB$log2FoldChange) > 0.59, "log2 fold change", "NS"))
)

colors <- c("p-value and log2 fold change" = "red",
            "p-value" = "blue",
            "log2 fold change" = "green",
            "NS" = "darkgrey")

p_volc_icB <- ggplot(lfcs_icB, aes(x = log2FoldChange, y = -log10(padj), color = Significance)) +
  geom_point(alpha = 0.5, aes(size = Significance)) +
  scale_color_manual(values = colors) +
  scale_size_manual(values = c("p-value and log2 fold change" = 1.5, "p-value" = 1.5, "log2 fold change" = 1.5, "NS" = 1)) +
  labs(title = "Volcano plot for BLZ ipsilateral vs contralateral",
       x = "log2 fold change", y = "-log10 adjusted p-value", color = "Significance") +
  theme_minimal() +
  theme(legend.position = "right",
