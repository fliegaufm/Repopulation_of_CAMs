  BLZ_ipsilateral_mean   = rowMeans(norm_counts_ipsi[, colData(dds_comb)$combined[ipsi_samples] == "BLZ945_ipsilateral", drop = FALSE])
)

category_mapping <- stack(macrophage_functions)
colnames(category_mapping) <- c("Gene", "Category")

mean_counts <- mean_counts %>%
  left_join(category_mapping, by = "Gene") %>%
  arrange(Category, Gene)

write.table(mean_counts, file.path(TABLES_DIR, "mean_counts_stroke_cams.txt"), sep = "\t", quote = FALSE, row.names = FALSE)

cat("Mean counts table exported to:", file.path(TABLES_DIR, "mean_counts_stroke_cams.txt"), "\n")

