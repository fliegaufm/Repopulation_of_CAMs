# Function to generate boxplots for a gene list (as in original)
generate_plots <- function(genes, category_name) {
  genes <- intersect(genes, rownames(dds_comb))
  if (length(genes) == 0) {
    message(paste("No genes from", category_name, "found in dds_comb"))
    return(NULL)
  }
  
  plots <- lapply(genes, function(g) {
    tryCatch({
      df <- plotCounts(dds_comb, gene = g, intgroup = "combined", returnData = TRUE)
      df$log_count <- log2(df$count + 1)
      
      anova_result <- aov(log_count ~ combined, data = df)
      anova_p <- summary(anova_result)[[1]][["Pr(>F)"]][1]
      
      if (anova_p < 0.05) {
        tukey_result <- TukeyHSD(anova_result)
        p_vals <- tukey_result$combined[, "p adj"]
        sig_p_vals <- p_vals[p_vals < 0.05]
        labels <- if (length(sig_p_vals) > 0) {
          paste(names(sig_p_vals), sprintf("p=%.5f", sig_p_vals), sep = ": ")
        } else {
          "No sig. pairwise diffs"
        }
      } else {
        labels <- "ANOVA NS"
      }
      
      p <- ggplot(df, aes(x = combined, y = count, fill = combined)) +
        geom_boxplot(outlier.shape = NA) +
        geom_jitter(width = 0.2, alpha = 0.6) +
        labs(title = g, x = "", y = "Normalized Counts") +
        theme_minimal() +
        theme(axis.text.x = element_blank(),
              axis.title.x = element_blank(),
              legend.position = "none") +
        annotate("text", x = Inf, y = Inf, label = paste(labels, collapse = "\n"),
                 hjust = 1, vjust = 1, size = 2.5, color = "black")
      
      return(p)
    }, error = function(e) {
      message(paste("Error with gene", g, "in", category_name, ":", e$message))
      return(NULL)
    })
  })
  
  plots <- plots[!sapply(plots, is.null)]
  
  if (length(plots) > 0) {
    combined_plot <- ggarrange(plotlist = plots,
                               ncol = 4,
                               nrow = ceiling(length(plots) / 4),
                               common.legend = TRUE,
                               legend = "right") +
      ggtitle(category_name) +
      theme(plot.title = element_text(size = 16, face = "bold", hjust = 0.5))
    return(combined_plot)
  } else {
    return(NULL)
  }
}

