  geom_vline(xintercept = c(-0.59, 0.59), linetype = "dashed", color = "darkgrey", linewidth = 0.5) +
  geom_hline(yintercept = -log10(0.05), linetype = "dashed", color = "darkgrey", linewidth = 0.5) +
  geom_text(data = subset(lfcs_icB, padj < 0.05 & abs(log2FoldChange) > 0.59),
