# ── 16. Stroke milieu genes boxplots on CAMs ──────────────────────────────────
colData_stroke <- combined_colData[combined_colData$combined1 %in% c("neg_V_Stroke", "neg_B_Stroke", "pos_B_Stroke"), ]
count_filt_stroke <- count_filtered[, colnames(count_filtered) %in% colData_stroke$Sample]

design_formula_stroke <- ~ combined1

dds_stroke <- DESeqDataSetFromMatrix(
  countData = count_filt_stroke,
  colData   = colData_stroke,
  design    = design_formula_stroke
)

dds_stroke <- estimateSizeFactors(dds_stroke)
dds_stroke <- DESeq(dds_stroke)

genes <- intersect(common_stroke_genes, rownames(dds_stroke))

plots <- lapply(genes, function(g) {
  df <- plotCounts(dds_stroke, gene = g, intgroup = "combined1", returnData = TRUE)
  df$log_count <- log2(df$count + 1)
  
  anova_result <- aov(log_count ~ combined1, data = df)
  anova_p <- summary(anova_result)[[1]][["Pr(>F)"]][1]
  
  if (anova_p < 0.05) {
    tukey_result <- TukeyHSD(anova_result)
    p_vals <- tukey_result$combined1[, "p adj"]
    sig_p_vals <- p_vals[p_vals < 0.05]
    labels <- if (length(sig_p_vals) > 0) {
      paste(names(sig_p_vals), sprintf("p=%.5f", sig_p_vals), sep = ": ")
    } else {
      "No sig. pairwise diffs"
    }
  } else {
    labels <- "ANOVA NS"
  }
  
  p <- ggplot(df, aes(x = combined1, y = count, fill = combined1)) +
    geom_boxplot(outlier.shape = NA) +
    geom_jitter(width = 0.2, alpha = 0.6) +
    labs(title = g, x = "", y = "Normalized Counts") +
    theme_minimal() +
    theme(axis.text.x = element_blank(),
          axis.title.x = element_blank(),
          legend.position = "none") +
    annotate("text", x = Inf, y = Inf, label = paste(labels, collapse = "\n"),
             hjust = 1, vjust = 1, size = 2.5, color = "black")
  
  return(p)
})

combined_plot <- ggarrange(plotlist = plots,
                           ncol = 4,
                           nrow = ceiling(length(plots) / 4),
                           common.legend = TRUE,
                           legend = "right")

pdf(file.path(FIGURES_DIR, "boxplots_stroke_milieu_genes_on_CAMs.pdf"), width = 15, height = 10)
print(combined_plot)
