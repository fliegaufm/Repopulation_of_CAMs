  Gene = rownames(norm_counts_ipsi),
  BLZ945_ipsi = rowMeans(norm_counts_ipsi[, colData(dds_comb)$combined[ipsi_samples] == "BLZ945_ipsilateral", drop = FALSE]),
  Veh_ipsi    = rowMeans(norm_counts_ipsi[, colData(dds_comb)$combined[ipsi_samples] == "Veh_ipsilateral", drop = FALSE])
)

