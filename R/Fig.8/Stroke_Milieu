  geom_bar(stat = "identity", width = 0.6) +
  labs(title = paste("Number of Overlapping Genes Higher in Ipsilateral Conditions\nChi-Square p =", p_value),
       x = "Condition", y = "Number of Genes") +
  scale_fill_manual(values = c("BLZ945_ipsilateral" = "#E69F00", "Veh_ipsilateral" = "#56B4E9")) +
  theme_minimal() +
  theme(legend.position = "none", axis.text.x = element_text(angle = 45, hjust = 1))

